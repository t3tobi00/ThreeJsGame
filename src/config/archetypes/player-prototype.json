{
    "_doc": "Prototype-mode player. Extends the legacy player.json. HP + slow regen are derived from balance.json (combat.player.HP, combat.player.regen_*). InventoryStack slotCapacity is bumped to balance.economy.carry_capacity_per_slot (default 30). Sword skill nulled out — auto-aim gun (Component_Gun + PlayerGunSystem) is the active weapon for the prototype feel-test. Trees can't be chopped while the sword is disabled; this is intentional for the gun-only test pass.",
    "extends": "player",
    "components": {
        "Health": {
            "hp":    "$balance.combat.player.HP",
            "maxHp": "$balance.combat.player.HP",
            "armor": 0
        },
        "Regen": {
            "ratePerSec":    "$balance.combat.player.regen_rate",
            "oocThreshold":  "$balance.combat.player.regen_OOC_threshold"
        },
        "InventoryStack": {
            "maxSlots":     3,
            "slotCapacity": "$balance.economy.carry_capacity_per_slot",
            "anchorOffset": { "x": 0, "y": 1.55, "z": -0.5 },
            "slotSpacing":  1.5,
            "style":        "wobble"
        },
        "SkillLoadout": {
            "activeSkill": null
        },
        "Gun": {
            "damage": 10,
            "fireRate": 2.5,
            "range": 12,
            "bulletSpeed": 70,
            "bulletMaxRange": 16,
            "targetFactions": ["enemy", "rival"],
            "muzzleHeight": 1.0,
            "chopRange": 2.5,
            "chopCooldown": 0.35,
            "chopDamage": 2
        },
        "Collector": {
            "pullForce": 2,
            "pickupRate": 0.1
        }
    }
}
