{
    "_doc": "Builder — Act 3 ally automation. Visual: yellow body + hard-hat + wrench. Scans active ghost zones, withdraws matching resources from storage, walks to zone, deposits (mutates UnlockZone.progress directly; emits zone:funded when complete). Pulls from storage, NOT the player's stack. Stats from balance.json combat.worker.* — speed bumped slightly (3.5) since builder is a courier. Cost economy.worker_cost.essence_cost.",
    "type": "WorkerBuilder",
    "spawn": {
        "cost": { "essence": "$balance.economy.worker_cost.essence_cost" }
    },
    "mesh": {
        "preset": "character-worker",
        "color":  "0xddcc22",
        "hat":    "hardhat",
        "tool":   "wrench"
    },
    "components": {
        "Health": {
            "hp":    "$balance.combat.worker.HP",
            "maxHp": "$balance.combat.worker.HP",
            "armor": 0
        },
        "Animator": {},
        "SquashStretch": { "intensity": 0.12, "frequency": 5, "trigger": "move" },
        "FlashAnim":     { "color": "0xff0000", "duration": 0.15, "onEvent": "entity:damaged" },
        "WalkAnim":      { "bobHeight": 0.06, "bobFreq": 6, "tiltAngle": 0.04 },
        "Collider":      { "shape": "circle", "radius": 0.35, "isStatic": false },
        "Tag":           { "tags": ["ally", "worker", "worker-builder"] },
        "Movement":      { "speed": 3.5, "controller": "none", "faction": "ally" },
        "InventoryStack": { "maxSlots": 2, "slotCapacity": 20, "acceptsTypes": ["wood", "essence"] },
        "WorkerAI": {
            "role":         "builder",
            "scanRadius":   25,
            "depositRange": 2.0
        }
    }
}
