{
    "_doc": "Prototype-mode zombie (V1 Shambler). Extends legacy enemy.json. All combat numbers come from balance.json combat.zombie.* — HP, contact damage, cooldown, speed. Spitter cooldown also balance-derived; spit damage uses zombie.spit_damage. EnemyAI: senseRadius 8 + wanderLeash 12 anchor wander to the OWN cemetery spawn point. aggroPriority drives closest+worker-preference targeting in EnemySystem._pickNearestTarget. wanderPause matches V1 PHASE_2_ENTITIES.md §2.5.4. Mesh + WalkAnim are the rigged 'character-zombie' so PlayerAnimSystem drives the lurch and LungeAnimSystem swings arms on each ContactDamage hit.",
    "extends": "enemy",
    "mesh": { "preset": "character-zombie", "color": "0x6a8a4a" },
    "components": {
        "Health":        {
            "hp":    "$balance.combat.zombie.HP",
            "maxHp": "$balance.combat.zombie.HP",
            "armor": 0
        },
        "Movement":      {
            "speed":      "$balance.combat.zombie.speed",
            "controller": "simple_steering",
            "faction":    "enemy"
        },
        "ContactDamage": {
            "damage":         "$balance.combat.zombie.damage_per_hit",
            "cooldown":       "$balance.combat.zombie.cooldown",
            "range":          2.0,
            "targetFactions": ["player", "ally", "structure"]
        },
        "Spitter":       {
            "range":            5.0,
            "cooldown":         "$balance.combat.zombie.spit_cooldown",
            "damage":           "$balance.combat.zombie.spit_damage",
            "windupDuration":   0.45,
            "projectileSpeed":  9,
            "arcHeight":        1.2,
            "targetFactions":   ["player", "ally", "structure"]
        },
        "EnemyAI":       {
            "senseRadius":      8,
            "wanderLeash":      12,
            "aggroRadius":      8,
            "wanderRadius":     12,
            "herdRadius":       5,
            "wanderSpeed":      0.9,
            "wanderPauseMin":   1.5,
            "wanderPauseMax":   3,
            "aggroPriority":    ["closest", "prefer_worker_on_tie"]
        },
        "WalkAnim":      { "bobHeight": 0.05, "bobFreq": 4, "tiltAngle": 0.10, "style": "zombie" }
    }
}
