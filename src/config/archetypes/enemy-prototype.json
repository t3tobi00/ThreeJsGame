{
    "_doc": "Prototype-mode zombie (V1 Shambler). Extends legacy enemy.json. Combat numbers from balance.json combat.zombie.*. 2026-05-12 (haunt pass): senseRadius 8→16 (twice the sight, see player at 16u), wanderLeash 12→35 (roam between cemeteries instead of orbiting one — required for 100u map), targetFactions now include 'rival' so zombies attack rival soldiers + king too (haunted-map-for-everyone). aggroPriority drives closest+worker-preference targeting in EnemySystem._pickNearestTarget.",
    "extends": "enemy",
    "mesh": { "preset": "character-zombie", "color": "0x6a8a4a" },
    "components": {
        "Health":        {
            "hp":    "$balance.combat.zombie.HP",
            "maxHp": "$balance.combat.zombie.HP",
            "armor": 0
        },
        "Movement":      {
            "speed":      "$balance.combat.zombie.speed",
            "controller": "simple_steering",
            "faction":    "enemy"
        },
        "ContactDamage": {
            "damage":         "$balance.combat.zombie.damage_per_hit",
            "cooldown":       "$balance.combat.zombie.cooldown",
            "range":          2.0,
            "targetFactions": ["player", "ally", "rival", "structure"]
        },
        "Spitter":       {
            "range":            5.0,
            "cooldown":         "$balance.combat.zombie.spit_cooldown",
            "damage":           "$balance.combat.zombie.spit_damage",
            "windupDuration":   0.45,
            "projectileSpeed":  9,
            "arcHeight":        1.2,
            "targetFactions":   ["player", "ally", "rival", "structure"]
        },
        "EnemyAI":       {
            "senseRadius":      16,
            "wanderLeash":      35,
            "aggroRadius":      16,
            "wanderRadius":     35,
            "herdRadius":       5,
            "wanderSpeed":      0.9,
            "wanderPauseMin":   1.5,
            "wanderPauseMax":   3,
            "aggroPriority":    ["closest", "prefer_worker_on_tie"]
        },
        "WalkAnim":      { "bobHeight": 0.05, "bobFreq": 4, "tiltAngle": 0.10, "style": "zombie" }
    }
}
