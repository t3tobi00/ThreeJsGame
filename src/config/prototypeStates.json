{
    "_doc": "Act 1 state machine per newGameDesign/PROTOTYPE_PLAN.md §4. Purely milestone-driven (no time-based auto-advance). Stall escalation is granular: each escalation tier checks WHAT specifically the player hasn't done (player inventory + zoneNotBuilt) and pushes a wave of marchers from the spawn point if the sub-step is still failing.",

    "firstState": "A",

    "spawnConfigs": {
        "spawn_a_baseline": {
            "_doc": "State A: light steady trickle while player picks off the 5 marchers.",
            "archetype": "enemy-prototype",
            "mode": "trickle", "interval": 2.5, "maxAlive": 6,
            "countMin": 1, "countMax": 1,
            "point": { "x": 0, "z": -22 }, "jitter": 4, "despawnDistance": 50
        },
        "spawn_b_baseline": {
            "_doc": "State B: trickle while player gathers wood + builds.",
            "archetype": "enemy-prototype",
            "mode": "trickle", "interval": 2.0, "maxAlive": 8,
            "countMin": 1, "countMax": 1,
            "point": { "x": 0, "z": -22 }, "jitter": 4, "despawnDistance": 50
        },
        "spawn_c_baseline": {
            "_doc": "State C: trickle as player kills for essence + spawns soldier.",
            "archetype": "enemy-prototype",
            "mode": "trickle", "interval": 1.8, "maxAlive": 9,
            "countMin": 1, "countMax": 1,
            "point": { "x": 0, "z": -22 }, "jitter": 4, "despawnDistance": 50
        },
        "spawn_d_baseline": {
            "_doc": "State D: trickle while player gathers + builds second wall.",
            "archetype": "enemy-prototype",
            "mode": "trickle", "interval": 1.5, "maxAlive": 10,
            "countMin": 1, "countMax": 2,
            "point": { "x": 0, "z": -22 }, "jitter": 4, "despawnDistance": 50
        },
        "spawn_g_baseline": {
            "_doc": "State G (PAD REVEAL): heavier trickle as Act 3 starts. Workers will eventually handle some load — for now this just keeps pressure up while the player drains 15E into the Worker Pad.",
            "archetype": "enemy-prototype",
            "mode": "trickle", "interval": 1.3, "maxAlive": 12,
            "countMin": 1, "countMax": 2,
            "point": { "x": 0, "z": -22 }, "jitter": 4, "despawnDistance": 50
        }
    },

    "states": {
        "A": {
            "_name": "BLOOD — survival burst",
            "_doc":  "Drop in. 5 marchers + 7 idlers near spawn. Exit: 5 zombie kills. If player stalls (5 not killed within 20s/40s), send a wave of marchers from spawn pt.",
            "entryActions": [
                { "call": "enemy.setSpawnConfig", "arg": "spawn_a_baseline" },
                { "call": "audio.cue",            "arg": "chime_info" }
            ],
            "exitTriggers": [
                { "event": "entity:died", "filter": { "faction": "enemy" }, "count": 5 }
            ],
            "stallEscalation": [
                {
                    "_doc": "20s in, still hasn't killed 5 — push 3 fresh marchers.",
                    "afterSeconds": 20,
                    "actions": [
                        { "call": "enemy.sendWave", "arg": { "count": 3, "archetype": "enemy-prototype-marcher" } },
                        { "call": "audio.cue", "arg": "chime_info" }
                    ]
                },
                {
                    "_doc": "40s in, still stalling — heavier wave + alert sting.",
                    "afterSeconds": 40,
                    "actions": [
                        { "call": "enemy.sendWave", "arg": { "count": 5, "archetype": "enemy-prototype-marcher" } },
                        { "call": "audio.cue", "arg": "alert_high" }
                    ]
                }
            ],
            "next": "B"
        },

        "B": {
            "_name": "DEFENSE — north wall",
            "_doc":  "North wall zone reveals. Also wakes the 7 idlers so they march south. Exit: north fence side built (zone:built tag north_wall_zone). Stall: no wood (15s) → has wood but not built (30s) → still nothing (45s).",
            "entryActions": [
                { "call": "enemy.activateReserves", "arg": null },
                { "call": "factory.activateGhost",  "arg": "north_wall_zone" },
                { "call": "pulseTrees",             "arg": true },
                { "call": "audio.cue",              "arg": "chime_info" },
                { "call": "enemy.setSpawnConfig",   "arg": "spawn_b_baseline" }
            ],
            "exitTriggers": [
                { "event": "zone:built", "filter": { "eventTag": "north_wall_zone" }, "count": 1 }
            ],
            "hints": [
                {
                    "_doc": "Wood < 10 — point at the nearest tree.",
                    "condition": { "playerInventoryLt": { "wood": 10 } },
                    "target": { "kind": "nearestTag", "tag": "tree" }
                },
                {
                    "_doc": "Have wood — point at north wall zone.",
                    "condition": { "playerInventoryGte": { "wood": 10 }, "zoneNotBuilt": "north_wall_zone" },
                    "target": { "kind": "tag", "tag": "north_wall_zone" }
                }
            ],
            "stallEscalation": [
                {
                    "_doc": "15s in, hasn't started chopping (wood < 5) — push wood pressure.",
                    "afterSeconds": 15,
                    "stallCondition": { "playerInventoryLt": { "wood": 5 } },
                    "actions": [
                        { "call": "enemy.sendWave", "arg": { "count": 3, "archetype": "enemy-prototype-marcher" } },
                        { "call": "audio.cue",      "arg": "chime_info" },
                        { "call": "hud.showAlert",  "arg": "Chop the trees!" }
                    ]
                },
                {
                    "_doc": "30s in, has wood but didn't build — push build pressure.",
                    "afterSeconds": 30,
                    "stallCondition": {
                        "playerInventoryGte": { "wood": 10 },
                        "zoneNotBuilt": "north_wall_zone"
                    },
                    "actions": [
                        { "call": "enemy.sendWave", "arg": { "count": 4, "archetype": "enemy-prototype-marcher" } },
                        { "call": "audio.cue",      "arg": "alert_high" },
                        { "call": "hud.showAlert",  "arg": "Build the north wall!" }
                    ]
                },
                {
                    "_doc": "45s in, still no north wall — heavy push.",
                    "afterSeconds": 45,
                    "stallCondition": { "zoneNotBuilt": "north_wall_zone" },
                    "actions": [
                        { "call": "enemy.sendWave", "arg": { "count": 6, "archetype": "enemy-prototype-marcher" } },
                        { "call": "audio.cue",      "arg": "alert_high" }
                    ]
                }
            ],
            "next": "C"
        },

        "C": {
            "_name": "ARMY — spawn pads",
            "_doc":  "Scout + Bruiser pads reveal. Exit: any soldier spawned. Stall checks: hasn't collected essence (15s)? has 4E but not spawned (30s)? Costs lowered to 4E (Scout) / 8E (Bruiser) while Act 3 is in development.",
            "entryActions": [
                { "call": "factory.activateGhost", "arg": "scout_pad" },
                { "call": "factory.activateGhost", "arg": "bruiser_pad" },
                { "call": "pulseTrees",            "arg": false },
                { "call": "audio.cue",             "arg": "chime_info" },
                { "call": "enemy.setSpawnConfig",  "arg": "spawn_c_baseline" }
            ],
            "exitTriggers": [
                { "event": "zone:spawned", "filter": { "archetype": "scout" },   "count": 1 },
                { "event": "zone:spawned", "filter": { "archetype": "bruiser" }, "count": 1 }
            ],
            "hints": [
                {
                    "_doc": "Essence < 4 — kill more zombies for essence.",
                    "condition": { "playerInventoryLt": { "essence": 4 } },
                    "target": { "kind": "nearestFaction", "faction": "enemy" }
                },
                {
                    "_doc": "Have 4E — drain into Scout Pad (cheaper of the two).",
                    "condition": { "playerInventoryGte": { "essence": 4 }, "zoneNotBuilt": "scout_pad" },
                    "target": { "kind": "tag", "tag": "scout_pad" }
                },
                {
                    "_doc": "Scout already spawned but bruiser hasn't — point at Bruiser Pad.",
                    "condition": { "playerInventoryGte": { "essence": 8 }, "zoneBuilt": "scout_pad", "zoneNotBuilt": "bruiser_pad" },
                    "target": { "kind": "tag", "tag": "bruiser_pad" }
                }
            ],
            "stallEscalation": [
                {
                    "_doc": "15s in, hasn't enough essence (need 4 for scout) — push for more kills.",
                    "afterSeconds": 15,
                    "stallCondition": { "playerInventoryLt": { "essence": 4 } },
                    "actions": [
                        { "call": "enemy.sendWave", "arg": { "count": 4, "archetype": "enemy-prototype-marcher" } },
                        { "call": "audio.cue",      "arg": "chime_info" },
                        { "call": "hud.showAlert",  "arg": "Kill zombies for essence!" }
                    ]
                },
                {
                    "_doc": "30s in, has 4E but didn't spawn a soldier — push for spawn.",
                    "afterSeconds": 30,
                    "stallCondition": { "playerInventoryGte": { "essence": 4 } },
                    "actions": [
                        { "call": "enemy.sendWave", "arg": { "count": 4, "archetype": "enemy-prototype-marcher" } },
                        { "call": "audio.cue",      "arg": "alert_high" },
                        { "call": "hud.showAlert",  "arg": "Stand on the Spawn Pad!" }
                    ]
                },
                {
                    "_doc": "45s in, no soldier yet — heavy push.",
                    "afterSeconds": 45,
                    "actions": [
                        { "call": "enemy.sendWave", "arg": { "count": 6, "archetype": "enemy-prototype-marcher" } },
                        { "call": "audio.cue",      "arg": "alert_high" }
                    ]
                }
            ],
            "next": "D"
        },

        "D": {
            "_name": "MULTI-FRONT — south wall",
            "_doc":  "South wall zone reveals. Exit: south fence side built. Stall: same wood/build cadence as B.",
            "entryActions": [
                { "call": "factory.activateGhost", "arg": "south_wall_zone" },
                { "call": "pulseTrees",            "arg": true },
                { "call": "audio.cue",             "arg": "chime_info" },
                { "call": "enemy.setSpawnConfig",  "arg": "spawn_d_baseline" }
            ],
            "exitTriggers": [
                { "event": "zone:built", "filter": { "eventTag": "south_wall_zone" }, "count": 1 }
            ],
            "hints": [
                {
                    "_doc": "Wood < 10 — point at the nearest tree.",
                    "condition": { "playerInventoryLt": { "wood": 10 } },
                    "target": { "kind": "nearestTag", "tag": "tree" }
                },
                {
                    "_doc": "Have wood — point at south wall zone.",
                    "condition": { "playerInventoryGte": { "wood": 10 }, "zoneNotBuilt": "south_wall_zone" },
                    "target": { "kind": "tag", "tag": "south_wall_zone" }
                }
            ],
            "stallEscalation": [
                {
                    "_doc": "15s in, no fresh wood — push wood pressure.",
                    "afterSeconds": 15,
                    "stallCondition": { "playerInventoryLt": { "wood": 5 } },
                    "actions": [
                        { "call": "enemy.sendWave", "arg": { "count": 3, "archetype": "enemy-prototype-marcher" } },
                        { "call": "audio.cue",      "arg": "chime_info" },
                        { "call": "hud.showAlert",  "arg": "Chop more trees!" }
                    ]
                },
                {
                    "_doc": "30s in, has wood but no south wall — build pressure.",
                    "afterSeconds": 30,
                    "stallCondition": {
                        "playerInventoryGte": { "wood": 10 },
                        "zoneNotBuilt": "south_wall_zone"
                    },
                    "actions": [
                        { "call": "enemy.sendWave", "arg": { "count": 4, "archetype": "enemy-prototype-marcher" } },
                        { "call": "audio.cue",      "arg": "alert_high" },
                        { "call": "hud.showAlert",  "arg": "Build the south wall!" }
                    ]
                },
                {
                    "_doc": "45s in, no south wall regardless — heavy push.",
                    "afterSeconds": 45,
                    "stallCondition": { "zoneNotBuilt": "south_wall_zone" },
                    "actions": [
                        { "call": "enemy.sendWave", "arg": { "count": 6, "archetype": "enemy-prototype-marcher" } },
                        { "call": "audio.cue",      "arg": "alert_high" }
                    ]
                }
            ],
            "next": "E"
        },

        "E": {
            "_name": "EXTEND — east wall",
            "_doc":  "East wall zone reveals. Player extends the perimeter east. Same wood/build cadence as B/D.",
            "entryActions": [
                { "call": "factory.activateGhost", "arg": "east_wall_zone" },
                { "call": "pulseTrees",            "arg": true },
                { "call": "audio.cue",             "arg": "chime_info" },
                { "call": "enemy.setSpawnConfig",  "arg": "spawn_d_baseline" }
            ],
            "exitTriggers": [
                { "event": "zone:built", "filter": { "eventTag": "east_wall_zone" }, "count": 1 }
            ],
            "hints": [
                {
                    "condition": { "playerInventoryLt": { "wood": 10 } },
                    "target": { "kind": "nearestTag", "tag": "tree" }
                },
                {
                    "condition": { "playerInventoryGte": { "wood": 10 }, "zoneNotBuilt": "east_wall_zone" },
                    "target": { "kind": "tag", "tag": "east_wall_zone" }
                }
            ],
            "stallEscalation": [
                {
                    "afterSeconds": 30,
                    "stallCondition": { "zoneNotBuilt": "east_wall_zone" },
                    "actions": [
                        { "call": "enemy.sendWave", "arg": { "count": 4, "archetype": "enemy-prototype-marcher" } },
                        { "call": "audio.cue",      "arg": "alert_high" },
                        { "call": "hud.showAlert",  "arg": "Build the east wall!" }
                    ]
                }
            ],
            "next": "F"
        },

        "F": {
            "_name": "EXTEND — west wall",
            "_doc":  "West wall zone reveals. Final side of the perimeter.",
            "entryActions": [
                { "call": "factory.activateGhost", "arg": "west_wall_zone" },
                { "call": "pulseTrees",            "arg": true },
                { "call": "audio.cue",             "arg": "chime_info" },
                { "call": "enemy.setSpawnConfig",  "arg": "spawn_d_baseline" }
            ],
            "exitTriggers": [
                { "event": "zone:built", "filter": { "eventTag": "west_wall_zone" }, "count": 1 }
            ],
            "hints": [
                {
                    "condition": { "playerInventoryLt": { "wood": 10 } },
                    "target": { "kind": "nearestTag", "tag": "tree" }
                },
                {
                    "condition": { "playerInventoryGte": { "wood": 10 }, "zoneNotBuilt": "west_wall_zone" },
                    "target": { "kind": "tag", "tag": "west_wall_zone" }
                }
            ],
            "stallEscalation": [
                {
                    "afterSeconds": 30,
                    "stallCondition": { "zoneNotBuilt": "west_wall_zone" },
                    "actions": [
                        { "call": "enemy.sendWave", "arg": { "count": 4, "archetype": "enemy-prototype-marcher" } },
                        { "call": "audio.cue",      "arg": "alert_high" },
                        { "call": "hud.showAlert",  "arg": "Build the west wall!" }
                    ]
                }
            ],
            "next": "G"
        },

        "G": {
            "_name": "PAD REVEAL — Act 3 automation kickoff",
            "_doc":  "Perimeter sealed. Worker Pad ghost reveals (drains 15E for 3 workers). +15 zombies escalation on entry to keep heat up while the player gathers essence. Exit: pad built. PR #3.0 routes G→END (placeholder); PR #3.4 inserts H AUTO_ACTIVE between them.",
            "entryActions": [
                { "call": "factory.activateGhost", "arg": "worker_pad" },
                { "call": "pulseTrees",            "arg": false },
                { "call": "audio.cue",             "arg": "chime_info" },
                { "call": "enemy.setSpawnConfig",  "arg": "spawn_g_baseline" },
                { "call": "enemy.sendWave",        "arg": { "count": 8, "archetype": "enemy-prototype-marcher" } },
                { "call": "hud.showAlert",         "arg": "Build the Worker Pad!" }
            ],
            "exitTriggers": [
                { "event": "zone:built", "filter": { "eventTag": "worker_pad" }, "count": 1 }
            ],
            "hints": [
                {
                    "_doc": "Essence < 15 — kill zombies for essence.",
                    "condition": { "playerInventoryLt": { "essence": 15 } },
                    "target": { "kind": "nearestFaction", "faction": "enemy" }
                },
                {
                    "_doc": "Have 15E — drain into Worker Pad.",
                    "condition": { "playerInventoryGte": { "essence": 15 }, "zoneNotBuilt": "worker_pad" },
                    "target": { "kind": "tag", "tag": "worker_pad" }
                }
            ],
            "stallEscalation": [
                {
                    "_doc": "30s in, no Worker Pad built — push pressure.",
                    "afterSeconds": 30,
                    "stallCondition": { "zoneNotBuilt": "worker_pad" },
                    "actions": [
                        { "call": "enemy.sendWave", "arg": { "count": 5, "archetype": "enemy-prototype-marcher" } },
                        { "call": "audio.cue",      "arg": "alert_high" },
                        { "call": "hud.showAlert",  "arg": "Build the Worker Pad!" }
                    ]
                }
            ],
            "next": "H"
        },

        "H": {
            "_name": "AUTO ACTIVE — placeholder before END",
            "_doc":  "PR #3.0 stub of the eventual H AUTO_ACTIVE state. Real version (PR #3.4) will gate on the 3-min Act-3 timer + worker activity. For now: hold long enough that the player can SEE the 3 placeholder workers around the pad, then exit on a small kill milestone (5 zombies) → END / Victory. Keeps the state machine milestone-driven (no time-based auto-advance).",
            "entryActions": [
                { "call": "audio.cue",            "arg": "chime_info" },
                { "call": "hud.showAlert",        "arg": "Workers spawned! Kill 5 zombies to win." },
                { "call": "enemy.setSpawnConfig", "arg": "spawn_g_baseline" }
            ],
            "exitTriggers": [
                { "event": "entity:died", "filter": { "faction": "enemy" }, "count": 5 }
            ],
            "next": "END"
        },

        "END": {
            "_name": "End of run (perimeter sealed)",
            "_doc":  "All 4 sides built. Triggers PrototypeEndUI Victory.",
            "entryActions": [
                { "call": "pulseTrees", "arg": false },
                { "call": "audio.cue",  "arg": "victory_chord" }
            ]
        }
    }
}
